<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a1200"/>
      <stop offset="50%" style="stop-color:#2a1f05"/>
      <stop offset="100%" style="stop-color:#1a1200"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="800" fill="url(#bg)"/>
  <text x="600" y="380" font-family="Arial, sans-serif" font-size="120" font-weight="bold" fill="#d4a02b" text-anchor="middle" opacity="0.8">🐂</text>
  <text x="600" y="480" font-family="Arial, sans-serif" font-size="36" font-weight="bold" fill="#d4a02b" text-anchor="middle" opacity="0.6">牛魔王</text>
  <text x="600" y="530" font-family="Arial, sans-serif" font-size="18" fill="#887744" text-anchor="middle" opacity="0.5">SINCE 1984</text>
  <!-- Decorative circles -->
  <circle cx="200" cy="650" r="80" fill="none" stroke="#d4a02b" stroke-width="1" opacity="0.15"/>
  <circle cx="1000" cy="150" r="60" fill="none" stroke="#d4a02b" stroke-width="1" opacity="0.12"/>
  <circle cx="1100" cy="700" r="40" fill="none" stroke="#d4a02b" stroke-width="1" opacity="0.1"/>
</svg>
